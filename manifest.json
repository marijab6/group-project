{
  "manifest_version": 3,
  "name": "RedFlag",
  "version": "1.0",
  "description": "Detects scam and phishing risks on websites.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "RedFlag"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}